<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================
    FILE: app/src/main/AndroidManifest.xml
    PROJECT: SecureBluetoothChat
    ============================================================

    PURPOSE:
        Central Android app declaration file defining:
          - app-level identity and theme
          - required permissions
          - hardware features
          - Activities and Services available to Android OS

    IMPORTANT NOTES:
        1) Runtime permissions still must be requested in Kotlin code.
           Manifest declarations only make permissions requestable.
        2) `android:exported` is required on Android 12+ for all
           components that can be launched externally.
        3) This app uses SecureChatApplication for process-wide bootstrap.
    ============================================================
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ====================================================================
         Bluetooth Permissions
         ==================================================================== -->

    <!-- Classic Bluetooth (Android < 12) -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- Bluetooth (Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- Required for BT device discovery on Android < 12 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:maxSdkVersion="30" />

    <!-- Foreground service for persistent Bluetooth connection -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
        tools:targetApi="34" />

    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        Hardware requirement:
        Required=true means Play/device filtering will avoid installs on
        devices lacking Bluetooth hardware.
    -->
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="true" />

    <!-- ====================================================================
         Application
         ==================================================================== -->

    <application
        android:name=".SecureChatApplication"
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SecureBluetoothChat.NoActionBar"
        tools:targetApi="34">

        <!-- ============================================================
             Activities
             ============================================================ -->

        <!-- Splash / Launcher -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SecureBluetoothChat.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Activity (entry point after splash) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Device List (discover / select devices) -->
        <activity
            android:name=".ui.device.DeviceListActivity"
            android:exported="false"
            android:label="@string/device_list_title" />

        <!-- Chat Screen -->
        <activity
            android:name=".ui.chat.ChatActivity"
            android:exported="false"
            android:label="@string/chat_title"
            android:windowSoftInputMode="adjustResize" />

        <!-- Settings -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title" />

        <!-- ============================================================
             Services
             ============================================================ -->

        <!-- Foreground service that keeps the Bluetooth connection alive -->
        <service
            android:name=".service.BluetoothChatService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

    </application>

</manifest>
