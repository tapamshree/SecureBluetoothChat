<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================
    FILE: res/drawable/bg_bubble_outgoing.xml
    PROJECT: SecureBluetoothChat
    ============================================================

    PURPOSE:
        The background shape drawable for OUTGOING (sent) message
        bubbles in the chat RecyclerView. Referenced by
        item_message.xml on the outgoing bubble container via:
            android:background="@drawable/bg_bubble_outgoing"

    WHAT THIS IS:
        A ShapeDrawable defined in XML using the <shape> tag.
        Android inflates this into a GradientDrawable at runtime.
        Using XML drawables keeps the UI:
          - resolution independent
          - lightweight (no bitmap decode)
          - theme/token driven via @color references
          - easy to tweak without touching Kotlin code

    VISUAL DESIGN:
        Outgoing bubbles use semantic token @color/bubble_outgoing
        with asymmetric corner radii to mimic the common chat-tail
        effect on the sender side.

        Corner radii:
            Top-left     : 18dp
            Top-right    : 18dp
            Bottom-left  : 18dp
            Bottom-right :  4dp   (directional corner / "tail" side)

        This asymmetry helps users instantly distinguish outgoing
        from incoming messages without reading extra labels.

    WHY NOT JUST USE A SOLID COLOR BACKGROUND:
        `android:background="@color/..."` creates a plain rectangle
        with sharp corners. Chat bubbles need rounded, directional
        geometry; shape XML is the standard Android approach.

    COLOR REFERENCE:
        @color/bubble_outgoing is defined in colors.xml and maps to
        a brand teal shade (currently palette_teal_600).

    USAGE:
        In message row layouts:
            android:background="@drawable/bg_bubble_outgoing"

        If runtime tinting is ever required (theme switching, debug mode):
            val bubble = ContextCompat.getDrawable(
                context, R.drawable.bg_bubble_outgoing
            ) as GradientDrawable
            bubble.setColor(ContextCompat.getColor(context, R.color.bubble_outgoing))

    RELATED FILE:
        bg_bubble_incoming.xml mirrors this shape and flips the
        directional corner to the opposite side.
    ============================================================
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!--
        FILL COLOR
        Solid background for sent messages. Uses semantic color token
        rather than hardcoded hex to preserve palette flexibility.
    -->
    <solid android:color="@color/bubble_outgoing" />

    <!--
        CORNER RADII
        Individual radii are used (instead of android:radius) so one
        corner can stay nearly flat, creating the directional bubble look.
    -->
    <corners
        android:topLeftRadius="18dp"
        android:topRightRadius="18dp"
        android:bottomLeftRadius="18dp"
        android:bottomRightRadius="4dp" />

    <!--
        PADDING
        Drawable-level padding is intentionally 0dp because padding is
        controlled at the message item container level for clarity.
    -->
    <padding
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp" />

</shape>
