<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================
    FILE: res/layout/activity_settings.xml
    PROJECT: SecureBluetoothChat
    ============================================================

    PURPOSE:
        Layout for SettingsActivity. This screen lets the user:
          1) Set a display name used in chat/session UI
          2) View encryption status (informational only, always ON)
          3) Clear local message history from Room database

    LAYOUT STRATEGY:
        Root: CoordinatorLayout
            Chosen so Snackbar/Material transient UI can anchor and
            behave consistently with AppBar content.
        Top: AppBarLayout + MaterialToolbar
            Provides title and back navigation affordance.
        Body: NestedScrollView + ConstraintLayout
            Ensures content remains accessible on small screens and
            when soft keyboard is visible.

    CONTENT SECTIONS:
        A) Profile Card    -> display name input + save button
        B) Security Card   -> encryption summary + lock status line
        C) Data Card       -> clear-history explanation + action button

    VIEW BINDING CONTRACT:
        ActivitySettingsBinding exposes important IDs:
          toolbar
          etDisplayName
          btnSaveDisplayName
          tvEncryptionSummary
          tvEncryptionStatus
          btnClearHistory
    ============================================================
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.settings.SettingsActivity">

    <!-- ========================================================
         APP BAR
         Fixed top bar containing title + navigation icon.
         ======================================================== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/toolbar_background"
        app:elevation="4dp">

        <!--
            Toolbar is wired as support action bar in SettingsActivity.
            Navigation click calls finish() to return to previous screen.
        -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/toolbar_background"
            app:navigationIcon="@android:drawable/ic_media_previous"
            app:title="@string/settings_title"
            app:titleTextColor="@color/text_primary"
            style="@style/Widget.SecureBluetoothChat.Toolbar" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ========================================================
         SCROLLABLE CONTENT
         fillViewport=true keeps content stretched to screen height
         even when content is short, preventing awkward empty top area.
         ======================================================== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="28dp">

            <!-- Screen heading -->
            <TextView
                android:id="@+id/settingsHeading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textAppearance="@style/TextAppearance.SecureBluetoothChat.HeadlineLarge"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Supporting subtitle -->
            <TextView
                android:id="@+id/settingsSubheading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:text="Manage your chat identity, security details, and saved messages."
                android:textAppearance="@style/TextAppearance.SecureBluetoothChat.BodySmall"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.3"
                app:layout_constraintTop_toBottomOf="@id/settingsHeading"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ====================================================
                 SECTION A: PROFILE
                 Display name preference.
                 ==================================================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profileCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/settingsSubheading"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_display_name"
                        android:textAppearance="@style/TextAppearance.SecureBluetoothChat.TitleMedium"
                        android:textColor="@color/text_primary" />

                    <!--
                        Filled input field for display name.
                        `actionDone` helps keyboard provide completion UX.
                    -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/displayNameInputLayout"
                        style="@style/Widget.SecureBluetoothChat.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/pref_display_name">

                        <!--
                            Single-line person-name input.
                            Value is loaded/saved via SharedPreferences.
                        -->
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDisplayName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:imeOptions="actionDone"
                            android:inputType="textPersonName"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            tools:text="Anonymous" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Save action -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveDisplayName"
                        style="@style/Widget.SecureBluetoothChat.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Save Display Name" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ====================================================
                 SECTION B: SECURITY
                 Informational status card. No toggle is exposed.
                 Encryption remains enforced by architecture.
                 ==================================================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/securityCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/profileCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_encryption_label"
                        android:textAppearance="@style/TextAppearance.SecureBluetoothChat.TitleMedium"
                        android:textColor="@color/text_primary" />

                    <!-- Human-readable summary of encryption mode -->
                    <TextView
                        android:id="@+id/tvEncryptionSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/pref_encryption_summary"
                        android:textAppearance="@style/TextAppearance.SecureBluetoothChat.BodySmall"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.3" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/pref_encryption_protocol"
                        android:textAppearance="@style/TextAppearance.SecureBluetoothChat.BodyMedium"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/pref_encryption_protocol_summary"
                        android:textAppearance="@style/TextAppearance.SecureBluetoothChat.BodySmall"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.3" />

                    <RadioGroup
                        android:id="@+id/rgEncryptionProtocol"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioEncryptionAes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/encryption_aes"
                            android:textColor="@color/text_primary"
                            app:buttonTint="@color/brand_primary" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioEncryptionRsa"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/encryption_rsa"
                            android:textColor="@color/text_primary"
                            app:buttonTint="@color/brand_primary" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioEncryptionTwofish"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/encryption_twofish"
                            android:textColor="@color/text_primary"
                            app:buttonTint="@color/brand_primary" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioEncryptionEcc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/encryption_ecc"
                            android:textColor="@color/text_primary"
                            app:buttonTint="@color/brand_primary" />

                    </RadioGroup>

                    <!-- Status row: lock icon + status text -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Lock icon (visual assurance cue) -->
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="8dp"
                            android:contentDescription="Encryption status icon"
                            android:src="@android:drawable/ic_lock_lock"
                            app:tint="@color/status_connected" />

                        <!-- Live status text populated from activity -->
                        <TextView
                            android:id="@+id/tvEncryptionStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/encrypted_label"
                            android:textAppearance="@style/TextAppearance.SecureBluetoothChat.BodyMedium"
                            android:textColor="@color/status_connected"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ====================================================
                 SECTION C: DATA
                 Destructive local cleanup action.
                 ==================================================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dataCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/securityCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data"
                        android:textAppearance="@style/TextAppearance.SecureBluetoothChat.TitleMedium"
                        android:textColor="@color/text_primary" />

                    <!-- Clarifies irreversibility before action -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp"
                        android:text="Clear local chat history on this device. This action cannot be undone."
                        android:textAppearance="@style/TextAppearance.SecureBluetoothChat.BodySmall"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.3" />

                    <!--
                        Destructive action button:
                        - styled as outlined to avoid over-emphasis
                        - red text/border communicates caution
                    -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearHistory"
                        style="@style/Widget.SecureBluetoothChat.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_clear_history"
                        android:textColor="@color/error"
                        app:strokeColor="@color/error" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
