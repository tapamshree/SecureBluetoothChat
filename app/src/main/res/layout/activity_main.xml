<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.SecureBluetoothChat.Toolbar.Home"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            app:title="@string/app_name"
            app:titleCentered="true"
            app:titleTextColor="@color/brand_primary_light" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="16dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_home_glow" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="6dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/appNameHero"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/hello"
                            android:textAppearance="@style/TextAppearance.SecureBluetoothChat.HeadlineLarge"
                            android:textColor="@color/brand_primary_light"
                            android:textSize="34sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingMultiplier="1.25"
                            android:text="@string/home_hero_subtitle"
                            android:textAppearance="@style/TextAppearance.SecureBluetoothChat.BodySmall"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/profileCard"
                        android:layout_width="92dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/brand_primary_light"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <ImageView
                                android:id="@+id/profileImage"
                                android:layout_width="54dp"
                                android:layout_height="54dp"
                                android:background="@drawable/bg_profile_avatar"
                                android:clipToOutline="true"
                                android:contentDescription="@string/profile_picture"
                                android:padding="12dp"
                                android:scaleType="centerCrop"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="@color/text_secondary" />

                            <TextView
                                android:id="@+id/profileName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:ellipsize="end"
                                android:gravity="center"
                                android:maxLines="1"
                                android:text="@string/pref_display_name_default"
                                android:textAppearance="@style/TextAppearance.SecureBluetoothChat.Caption"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </FrameLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statusCard"
                android:layout_width="357dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="338dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:id="@+id/btStatusIcon"
                        android:layout_width="50dp"
                        android:layout_height="49dp"
                        android:layout_marginEnd="14dp"
                        android:background="@drawable/bg_status_icon"
                        android:contentDescription="@string/bluetooth_status"
                        android:padding="7dp"
                        android:src="@android:drawable/stat_sys_data_bluetooth"
                        app:tint="@color/status_disconnected" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bluetooth_status"
                            android:textAppearance="@style/TextAppearance.SecureBluetoothChat.Caption"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/btStatusValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/status_disconnected"
                            android:textAppearance="@style/TextAppearance.SecureBluetoothChat.TitleMedium"
                            android:textColor="@color/status_disconnected"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="@string/home_choose_path"
                android:textAppearance="@style/TextAppearance.SecureBluetoothChat.TitleMedium"
                android:textColor="@color/text_primary" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnStartServer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/surface_variant"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/brand_primary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_action_badge"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@color/text_on_primary"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_start_server"
                            android:textAppearance="@style/TextAppearance.SecureBluetoothChat.TitleMedium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:lineSpacingMultiplier="1.25"
                            android:text="@string/server_mode_detail"
                            android:textAppearance="@style/TextAppearance.SecureBluetoothChat.BodySmall"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnStartClient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_action_badge_secondary"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_start_client"
                            android:textAppearance="@style/TextAppearance.SecureBluetoothChat.TitleMedium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:lineSpacingMultiplier="1.25"
                            android:text="@string/client_mode_detail"
                            android:textAppearance="@style/TextAppearance.SecureBluetoothChat.BodySmall"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/footerBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_footer_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/footer_copyright"
                    android:textAppearance="@style/TextAppearance.SecureBluetoothChat.Caption"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="@string/footer_creators"
                    android:textAppearance="@style/TextAppearance.SecureBluetoothChat.Caption"
                    android:textColor="@color/brand_primary_dark"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
